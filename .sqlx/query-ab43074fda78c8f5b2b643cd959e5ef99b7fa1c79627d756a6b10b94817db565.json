{
  "db_name": "PostgreSQL",
  "query": "SELECT tp.id, tp.slug::text, tp.name, tp.description, tp.git_remote, tp.stack_tags, tp.created_at, tp.updated_at, COALESCE(ic.cnt, 0) AS item_count FROM tenant_projects tp LEFT JOIN ( SELECT project_id, COUNT(*) AS cnt FROM tenant_project_items GROUP BY project_id ) ic ON ic.project_id = tp.id WHERE tp.tenant_id = $1 ORDER BY tp.slug ASC",
