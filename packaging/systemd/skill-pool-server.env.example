# skill-pool-server — environment for the systemd unit.
#
# Install location: /etc/skill-pool/skill-pool-server.env
# Mode: 0600, owned by skillpool:skillpool
#
# Variable prefix is SKILL_POOL_; nested keys use __ (double underscore)
# as the path separator (see server/src/config.rs).

# --- Required ---

# Postgres DSN. The server runs migrations on startup, so the role
# needs CREATE on the schema. For production prefer a separate
# migration role and pre-running `sqlx migrate run`.
SKILL_POOL_DATABASE_URL=postgres://skillpool:CHANGE_ME@127.0.0.1:5432/skillpool

# Optional read-replica DSN. When set, read-only handlers (catalog list,
# detail, deps, usage timelines, decay candidates) route here; everything
# else still hits the primary. Replication lag means a publish-then-list
# within milliseconds can see stale state — usually fine for the catalog.
# SKILL_POOL_DATABASE_READ_URL=postgres://skillpool:CHANGE_ME@replica.internal:5432/skillpool

# sqlx connection-pool max size. The read pool (when configured) uses
# the same cap. Default 20. Bump for high-traffic deployments: rough
# rule is (peak RPS × p95-seconds) + 20% headroom.
# SKILL_POOL_DB_POOL_SIZE=20

# HTTP bind. 0.0.0.0:8080 when fronted by a reverse proxy on the same
# host. 127.0.0.1:8080 if the proxy is local-only.
SKILL_POOL_BIND=127.0.0.1:8080

# Bundle storage backend. `fs://` for single-node, `s3://...` for cloud.
SKILL_POOL_STORAGE_URI=fs:///var/lib/skill-pool/bundles

# Fallback tenant when the Host header doesn't carry a subdomain.
# Production with proper subdomain routing: leave empty.
SKILL_POOL_DEFAULT_TENANT=acme

# Tenancy mode: "shared" (multi-tenant, default — tenant resolved from
# subdomain or X-Skill-Pool-Tenant header) or "dedicated" (single-tenant
# deploy — pin the tenant via SKILL_POOL_TENANCY_MODE__TENANT_SLUG below).
# See docs/enterprise/dedicated-mode.md for the full deploy pattern.
# SKILL_POOL_TENANCY_MODE__MODE=shared
# SKILL_POOL_TENANCY_MODE__TENANT_SLUG=acme

# --- Optional ---

# Logging. JSON is the default; "pretty" only for interactive debugging.
# RUST_LOG=info,skill_pool=info
# RUST_LOG_FORMAT=json

# OTLP exporter (only meaningful if built with --features otlp).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.internal:4318
# OTEL_SERVICE_NAME=skill-pool-server
